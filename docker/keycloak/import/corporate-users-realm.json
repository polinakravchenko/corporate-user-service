{
  "realm": "corporate-users",
  "enabled": true,
  "displayName": "Corporate Users Realm",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "Administrator with access to user management"
      },
      {
        "name": "CUSTOMER",
        "description": "Customer with access only to personal cabinet"
      }
    ]
  },
  "clients": [
    {
      "clientId": "corporate-user-service",
      "name": "Corporate User Service",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "corporate-user-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/login/oauth2/code/keycloak"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@example.com",
      "firstName": "System",
      "lastName": "Administrator",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "AdminPass123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    },
    {
      "username": "customer",
      "email": "customer@example.com",
      "firstName": "Demo",
      "lastName": "Customer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "CustomerPass123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "CUSTOMER"
      ]
    }
  ]
}
